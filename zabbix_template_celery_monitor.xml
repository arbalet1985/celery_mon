                    <key>celery.discover[tasks]</key>
                    <type>TRAP</type>
                    <delay>1h</delay>
                    <description>Requires UserParameter=celery.discover[*],/path/to/celery_monitor -A your_app --discover $1</description>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>2d8e4a2d-8f3e-4c75-9c3e-5d2a8f6b3e4a</uuid>
