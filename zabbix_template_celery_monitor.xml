                            <delay>0</delay>
                            <value_type>FLOAT</value_type>
                            <units>s</units>
                        </item_prototype>
                        <item_prototype>
                            <uuid>ab003f240fd54e49a6240aa890611dfa</uuid>
                            <name>Celery task succeeded [{#TASK_NAME}]</name>
                            <type>TRAP</type>
                            <key>celery.task.succeeded[{#TASK_NAME}]</key>
                            <delay>0</delay>
                            <value_type>FLOAT</value_type>
                        </item_prototype>
                    </item_prototypes>
                    <trigger_prototypes>
                        <trigger_prototype>
                            <uuid>3d1c86edcbff4069855372787d48fc3d</uuid>
                            <expression>sum(/Template App Celery Monitor/celery.task.succeeded[{#TASK_NAME}],24h)/
(
sum(/Template App Celery Monitor/celery.task.failed[{#TASK_NAME}],24h)
+
sum(/Template App Celery Monitor/celery.task.succeeded[{#TASK_NAME}],24h)
)&lt;0.7</expression>
                            <name>Celery Процент успешности запуска {#TASK_NAME} менее 70%</name>
                        </trigger_prototype>
                    </trigger_prototypes>
                </discovery_rule>
