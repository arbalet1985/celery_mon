                <discovery_rule>
                    <uuid>85a20d86d09d4e74947074ead3ac1010</uuid>
                    <name>Celery tasks discovery</name>
                    <type>TRAP</type>
                    <key>celery.discover[tasks]</key>
                    <delay>0</delay>
                    <description>LLD sent by celery_monitor daemon (config: discovery_interval). Or UserParameter=celery.discover[*],/path/to/celery_monitor -A your_app --discover $1</description>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>fc2f4b71f7dc4ba3b51de327f359203b</uuid>
                            <name>Celery prc succeeded task [{#TASK_NAME}]</name>
                            <type>CALCULATED</type>
                            <key>celery.prc.succeeded.task[{#TASK_NAME}]</key>
                            <delay>10m</delay>
                            <value_type>FLOAT</value_type>
                            <params>sum(//celery.task.succeeded[{#TASK_NAME}],24h)
/
(
sum(//celery.task.succeeded[{#TASK_NAME}],24h)
+
sum(//celery.task.failed[{#TASK_NAME}],24h)
)</params>
                        </item_prototype>
                        <item_prototype>
                            <uuid>be4401716abb4547ab89ce3f757b914d</uuid>
                            <name>Celery task error [{#TASK_NAME}]</name>
                            <type>TRAP</type>
                            <key>celery.task.error[{#TASK_NAME}]</key>
                            <delay>0</delay>
                            <trends>0</trends>
                            <value_type>TEXT</value_type>
                            <description>Last error message when task failed</description>
                        </item_prototype>
                        <item_prototype>
                            <uuid>80c2fe67c36a4d9aad17fe166782231a</uuid>
